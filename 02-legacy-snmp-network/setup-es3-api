#!/bin/bash
set -euo pipefail
ES_URL=\$(agent variable get ES_URL 2>/dev/null | tr -d '[:space:]' || echo "http://localhost:9200")
API_KEY=\$(agent variable get ELASTICSEARCH_API_KEY 2>/dev/null | tr -d '[:space:]' || echo "")

AUTH=""
[[ -n "\${API_KEY}" ]] && AUTH="-H \"Authorization: ApiKey \${API_KEY}\""

PASS=0; FAIL=0

check_count() {
  local label="\$1" index="\$2" query="\$3" min="\$4"
  local count
  count=\$(eval curl -sf \${AUTH} "\${ES_URL}/\${index}/_count?q=\${query}" 2>/dev/null \
    | python3 -c "import sys,json; print(json.load(sys.stdin).get('count',0))" 2>/dev/null || echo 0)
  if [[ "\${count}" -ge "\${min}" ]]; then
    printf "  \033[32m✓\033[0m %-40s → %s\n" "\${label}" "\${count} records"
    PASS=\$((PASS + 1))
  else
    printf "  \033[31m✗\033[0m %-40s → %s (need ≥%s)\n" "\${label}" "\${count}" "\${min}"
    FAIL=\$((FAIL + 1))
  fi
}

echo ""
echo "Validating Challenge 2 — SNMP + CMDB ingest..."
echo ""

check_count "CMDB index loaded"           "exxon-cmdb-devices"    "*" 12
check_count "SNMP trap data received"     "logs-snmp.trap-exxon"  "*"  1
check_count "linkDown events present"     "logs-snmp.trap-exxon"  "snmp.trap.type:linkDown" 2
check_count "Multi-site traps (houston)"  "logs-snmp.trap-exxon"  "device.hostname:cisco-sw-houston*" 1
check_count "Multi-site traps (midland)"  "logs-snmp.trap-exxon"  "device.hostname:cisco-sw-midland*" 1

echo ""
if [[ "\$FAIL" -eq 0 ]]; then
  echo "  \033[32m✓\033[0m CMDB enrichment applied — network.site populated"
  echo "  \033[32m✓\033[0m Multi-site link-down events confirmed"
  echo ""
  echo "  \033[32m✓ Challenge 2 complete — SNMP tamed, network events visible to app teams\033[0m"
else
  echo "  \${FAIL} check(s) failed."
  echo "  Steps to fix:"
  echo "    1. Run: /root/exxon-snmp/load-cmdb-data.sh"
  echo "    2. Run: /root/exxon-snmp/send-snmp-traps.sh"
  echo "    3. Wait 30s and run this script again."
fi
SCRIPT
