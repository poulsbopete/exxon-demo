# ── 7. queries/network-impact.esql ────────────────────────────────────────────
cat > "${SNMP_DIR}/queries/network-impact.esql" << 'ESQL'
// Network impact query — which teams are affected by current link-down events?
// Run in Elastic Serverless tab → Dev Tools → ES|QL

FROM logs-snmp.trap-exxon
| WHERE @timestamp > NOW() - 30 minutes
  AND snmp.trap.type == "linkDown"
| EVAL site = COALESCE(network.site, "unknown")
| EVAL owner = COALESCE(application.owner, "unknown")
| STATS
    link_down_count      = COUNT(*),
    affected_interfaces  = VALUES(network.interface)
  BY network.site, application.owner
| SORT link_down_count DESC
ESQL
log "Created ${SNMP_DIR}/queries/network-impact.esql ✓"

# ── 8. queries/thousandeyes-correlation.esql ──────────────────────────────────
cat > "${SNMP_DIR}/queries/thousandeyes-correlation.esql" << 'ESQL'
// ThousandEyes correlation — joins SNMP link-down events to circuit metrics.
// In a full deployment this reads from logs-thousandeyes.* via the
// ThousandEyes integration for Elastic Agent.

FROM logs-snmp.trap-exxon
| WHERE @timestamp > NOW() - 30 minutes
  AND snmp.trap.type == "linkDown"
| KEEP @timestamp, device.hostname, network.interface, thousandeyes.agent_id
| SORT @timestamp DESC
| LIMIT 20

// In a full deployment you would JOIN to metrics-thousandeyes.* on
// thousandeyes.agent_id to add: packet_loss_pct, jitter_ms, latency_ms
ESQL
log "Created ${SNMP_DIR}/queries/thousandeyes-correlation.esql ✓"

