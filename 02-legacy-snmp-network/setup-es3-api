#!/bin/bash
# Challenge 2 setup — create all /root/exxon-snmp/ files the assignment
# references, then verify the demo app is healthy.
set -euo pipefail

DEMO_PORT=8090
SNMP_DIR="/root/exxon-snmp"
log() { printf "[challenge-2-setup] %s\n" "$*"; }

# ── 1. Wait for demo app ───────────────────────────────────────────────────────
log "Checking demo app health..."
for i in $(seq 1 20); do
  curl -sf "http://localhost:${DEMO_PORT}/health" >/dev/null 2>&1 && { log "Demo app healthy ✓"; break; }
  [[ $i -eq 20 ]] && { systemctl restart exxon-demo; sleep 8; }
  sleep 2
done

# ── 2. Read credentials ────────────────────────────────────────────────────────
ES_URL=$(agent variable get ES_URL 2>/dev/null | tr -d '[:space:]' || echo "http://localhost:9200")
API_KEY=$(agent variable get ELASTICSEARCH_API_KEY 2>/dev/null | tr -d '[:space:]' || echo "")
[[ -z "$API_KEY" && -f /root/.elastic-creds ]] && source /root/.elastic-creds

mkdir -p "${SNMP_DIR}/queries"

# ── 3. sample-traps.txt ───────────────────────────────────────────────────────
cat > "${SNMP_DIR}/sample-traps.txt" << 'TXT'
