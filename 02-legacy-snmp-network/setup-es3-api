#!/bin/bash
# Simulate Cisco SNMP traps being received and indexed into Elastic Serverless.
# In production these come via snmptrapd → Elastic Agent SNMP integration.
# Here we POST pre-translated NDJSON directly to demonstrate the data model.
set -euo pipefail

ES_URL=\$(agent variable get ES_URL 2>/dev/null | tr -d '[:space:]' || echo "http://localhost:9200")
API_KEY=\$(agent variable get ELASTICSEARCH_API_KEY 2>/dev/null | tr -d '[:space:]' || echo "")

AUTH=""
[[ -n "\${API_KEY}" ]] && AUTH="-H \"Authorization: ApiKey \${API_KEY}\""

NOW=\$(date -u +%Y-%m-%dT%H:%M:%SZ)

post_trap() {
  local trap_json="\$1"
  local label="\$2"
  eval curl -sf -X POST \\
    "\${ES_URL}/logs-snmp.trap-exxon/_doc" \\
    -H "'Content-Type: application/json'" \\
    \${AUTH} \\
    -d "'\${trap_json}'" >/dev/null \
    && echo "  [INFO] Sent trap: \${label}"
}

echo "Sending simulated Cisco SNMP traps to Elastic Serverless..."
echo ""

post_trap '{"@timestamp":"'"$NOW"'","event.kind":"event","event.category":"network","event.type":["connection","end"],"snmp.trap.type":"linkDown","snmp.trap.oid":".1.3.6.1.6.3.1.1.5.3","device.hostname":"cisco-sw-houston-01","device.ip":"10.12.5.22","network.interface":"GigabitEthernet0/47","network.interface_index":47,"snmp.community":"exxon-public","snmp.version":"v2c","cmdb.ci_class":"Cisco Catalyst 9300"}' \
