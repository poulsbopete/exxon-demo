log "Created ${SNMP_DIR}/sample-traps.txt ✓"

# ── 4. elastic-agent-snmp.yml ─────────────────────────────────────────────────
cat > "${SNMP_DIR}/elastic-agent-snmp.yml" << YAML
# Elastic Agent — Network SNMP Integration config
# This would be deployed on the Elastic Fleet server that faces the network.

inputs:
  - type: snmp
    streams:
      - listen_address: "0.0.0.0:1620"
        community: "exxon-public"
        version: v2c
        translate_oids: true
        mib_paths:
          - /etc/elastic-agent/mib
        fields:
          network.site: ""        # populated by enrich policy at query time
          cmdb.owner_team: ""     # populated by enrich policy at query time

    output.elasticsearch:
      hosts: ["${ES_URL:-http://localhost:9200}"]
      api_key: "${API_KEY:-<set ELASTICSEARCH_API_KEY>}"
      indices:
        - index: "logs-snmp.trap-exxon"
          when.equals:
            snmp.trap.type: "linkDown"
        - index: "logs-snmp.trap-exxon"
          when.equals:
            snmp.trap.type: "linkUp"
YAML
log "Created ${SNMP_DIR}/elastic-agent-snmp.yml ✓"

