#!/bin/bash
# Track-level cleanup — runs when the sandbox is destroyed.
# Deletes the provisioned Elastic Cloud Serverless project.
set -euo pipefail

DEPLOYMENT_ID=$(agent variable get ES_DEPLOYMENT_ID 2>/dev/null || echo "")

if [ -z "${PME_CLOUD_INSTRUQT_API_KEY:-}" ]; then
    PME_CLOUD_INSTRUQT_API_KEY="${ESS_CLOUD_API_KEY:-}"
fi
if [ -z "${PME_CLOUD_INSTRUQT_API_KEY:-}" ]; then
    PME_CLOUD_INSTRUQT_API_KEY=$(agent variable get ESS_CLOUD_API_KEY 2>/dev/null || echo "")
fi

if [ -n "$DEPLOYMENT_ID" ] && [ -n "${PME_CLOUD_INSTRUQT_API_KEY:-}" ]; then
    echo "Deleting Elastic Cloud project: $DEPLOYMENT_ID"
    python3 bin/es3-api.py \
        --operation delete \
        --project-id "$DEPLOYMENT_ID" \
        --api-key "$PME_CLOUD_INSTRUQT_API_KEY" || echo "WARN: Project deletion may have failed — check Elastic Cloud console"
    echo "Project deleted ✓"
else
    echo "WARN: No deployment ID or API key found — skipping project deletion"
fi

systemctl stop exxon-demo 2>/dev/null || true
echo "Cleanup complete ✓"
