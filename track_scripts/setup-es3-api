        print("     WAN DNS jitter causing Azure AD auth timeouts (Event 4625).")
        print("     AppGate and iboss are NOT blocking. WAN team issue.")
        print("     Fix: investigate DNS server 10.14.1.53 in Midland.")
    elif aws: print("  → ROOT CAUSE: AWS_FALLBACK")
    elif ag:  print("  → ROOT CAUSE: APPGATE_POLICY")
    else:     print("  → ROOT CAUSE: UNDETERMINED")
    print(f"{'='*55}\n")

p = argparse.ArgumentParser()
p.add_argument("--check", choices=["aws-fallback","jitter-dns","appgate-block"])
p.add_argument("--full-report", action="store_true")
p.add_argument("--user", default="jsmith")
args = p.parse_args()
if args.check == "aws-fallback":   check_aws(args.user)
elif args.check == "jitter-dns":   check_dns(args.user)
elif args.check == "appgate-block":check_appgate(args.user)
elif args.full_report:             full_report(args.user)
else: p.print_help()
