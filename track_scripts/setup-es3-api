#!/usr/bin/env python3
"""EUX Investigation — python3 investigate.py --full-report --user jsmith"""
import argparse, json
from pathlib import Path
DATA = Path("/root/exxon-eux/data")
def load(n): return [json.loads(l) for l in DATA.joinpath(n).read_text().splitlines() if l.strip()]

def check_aws(user):
    te = [d for d in load("thousandeyes-metrics.json") if "midland" in d.get("thousandeyes.agent.name","").lower()]
    ok = any(d.get("thousandeyes.net.loss_pct",0)>5 or d.get("thousandeyes.net.latency_ms",0)>150 for d in te)
    max_loss = max((d.get("thousandeyes.net.loss_pct",0) for d in te), default=0)
    max_lat  = max((d.get("thousandeyes.net.latency_ms",0) for d in te), default=0)
    print(f"\n  AWS Fallback: max_loss={max_loss:.1f}% (thresh 5%), max_latency={max_lat}ms (thresh 150ms)")
    print(f"  → {'TRIGGERED' if ok else 'NOT triggered'}")
    return ok

def check_dns(user):
    te = [d for d in load("thousandeyes-metrics.json") if "midland" in d.get("thousandeyes.agent.name","").lower()]
    wins = [d for d in load("windows-events.json") if d.get("user.name")==user and d.get("winlog.event_id")==4625]
    high_j = any(d.get("thousandeyes.net.jitter_ms",0)>20 for d in te)
    max_j = max((d.get("thousandeyes.net.jitter_ms",0) for d in te), default=0)
    max_dns = max((d.get("thousandeyes.dns.rtt_ms",0) for d in te), default=0)
    print(f"\n  Jitter DNS: max_jitter={max_j}ms (thresh 20ms), Event-4625 count={len(wins)}")
    ok = high_j and bool(wins)
    print(f"  → {'TRIGGERED' if ok else 'NOT triggered'}")
    return ok

def check_appgate(user):
    denied = [d for d in load("appgate-audit.json") if d.get("user.name")==user and d.get("event.outcome")=="denied"]
    blocked = [d for d in load("iboss-connections.json") if d.get("user.name")==user and d.get("event.outcome")=="blocked" and "audit" in d.get("destination.domain","")]
    print(f"\n  AppGate/iboss: denied={len(denied)}, iboss-blocked-audit={len(blocked)}")
    ok = bool(denied or blocked)
    print(f"  → {'TRIGGERED' if ok else 'NOT triggered'}")
    return ok

def full_report(user):
    print(f"\n{'='*55}\n  Exxon EUX Investigation — user: {user}\n{'='*55}")
    aws = check_aws(user); dns = check_dns(user); ag = check_appgate(user)
