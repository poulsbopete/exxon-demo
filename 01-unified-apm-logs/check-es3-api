#!/usr/bin/env bash
# =============================================================================
# Challenge 1 Check — verify the Exxon scenario is active and telemetry flows
# Exit 0 = pass, Exit 1 = fail
# =============================================================================
DEMO_PORT=8090

fail() {
    export INSTRUQT_FAIL_MESSAGE="$*"
    echo "FAIL: $*"
    exit 1
}

# 1. Demo app must be reachable
curl -sf "http://localhost:${DEMO_PORT}/health" >/dev/null 2>&1 \
    || fail "Demo App is not responding on port ${DEMO_PORT}. The track may still be setting up — wait 30 seconds and try again."

# 2. Exxon scenario must be running
DEPLOYMENTS=$(curl -sf "http://localhost:${DEMO_PORT}/api/deployments" 2>/dev/null || echo "[]")
RUNNING=$(echo "$DEPLOYMENTS" | python3 -c "
import sys, json
d = json.load(sys.stdin)
print(any(x.get('scenario_id') == 'exxon' and x.get('running') for x in d))
" 2>/dev/null || echo "False")

[[ "$RUNNING" == "True" ]] \
    || fail "The Exxon Infrastructure 2.0 scenario is not running yet. Switch to the Demo App tab, wait for the Deployment Progress to show green checkmarks, then try again."

# 3. At least one OTLP stream must have data (check via Streams API proxy)
PROGRESS=$(curl -sf "http://localhost:${DEMO_PORT}/api/setup/progress?deployment_id=exxon" 2>/dev/null || echo "{}")
FINISHED=$(echo "$PROGRESS" | python3 -c "import sys,json; p=json.load(sys.stdin); print(p.get('finished', False))" 2>/dev/null || echo "False")

if [[ "$FINISHED" != "True" ]]; then
    fail "Deployment is still in progress. Switch to the Demo App tab and wait for all steps to show green checkmarks, then try Check again."
fi

echo "Challenge 1 passed: Exxon scenario is active and deployment is complete."
exit 0
