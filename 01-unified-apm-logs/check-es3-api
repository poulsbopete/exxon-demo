#!/usr/bin/env bash
# Challenge 1 check — deployment must be fully complete.
APP="http://localhost:8090"

fail() { echo "FAIL: $*" >&2; exit 1; }

# Demo App must be reachable
curl -sf "${APP}/health" >/dev/null 2>&1 \
    || fail "Demo App not responding. The track may still be setting up — wait 30 seconds and try again."

# Ask the app whether challenge 1 is satisfied
RESULT=$(curl -sf "${APP}/api/check/1" 2>/dev/null || echo '{"ok":false,"reason":"Could not reach check endpoint"}')
OK=$(echo "$RESULT" | python3 -c "import sys,json; print(json.load(sys.stdin).get('ok',False))" 2>/dev/null || echo "False")
REASON=$(echo "$RESULT" | python3 -c "import sys,json; print(json.load(sys.stdin).get('reason','unknown'))" 2>/dev/null || echo "unknown")

[[ "$OK" == "True" ]] || fail "$REASON"
echo "Challenge 1 passed: $REASON"
exit 0
