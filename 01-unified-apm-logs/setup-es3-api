#!/bin/bash
# Challenge 1 setup — files already exist from track_scripts/setup-es3-api.
# Just verify the demo app is running; warn but don't fail if it isn't.
DEMO_PORT=8090
log() { printf "[challenge-1-setup] %s\n" "$*"; }

for i in $(seq 1 15); do
  curl -sf "http://localhost:${DEMO_PORT}/health" >/dev/null 2>&1 && { log "Demo app healthy ✓"; exit 0; }
  sleep 2
done

log "WARN: Demo app not responding — attempting restart..."
systemctl restart exxon-demo 2>/dev/null || true
sleep 8
curl -sf "http://localhost:${DEMO_PORT}/health" >/dev/null 2>&1 \
  && log "Demo app healthy after restart ✓" \
  || log "WARN: App still not healthy. Run in Terminal: journalctl -u exxon-demo -n 50"

# Files are created by track_scripts/setup-es3-api — verify they exist
ls /root/exxon-otel/otel-collector-config.yaml >/dev/null 2>&1 \
  && log "Challenge files ready ✓" \
  || log "WARN: /root/exxon-otel/ not found — track setup may still be running"

exit 0
