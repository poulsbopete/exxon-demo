# ============================================================================
# Elastic Observability Demo Platform — Environment Configuration
# ============================================================================
# Deployment credentials (Elastic URL, API key, Kibana URL, OTLP endpoint)
# are persisted in the app's SQLite database (data/deployments.db) when you
# deploy via the web UI. You do NOT need to set them here.
#
# This file is for optional app-level overrides only (notification configs,
# port, active scenario, etc.).  Copy to .env and fill in values as needed:
#   cp .env.example .env
# ============================================================================

# ── App Settings ─────────────────────────────────────────────────────────────
# Default scenario to load on startup.
#ACTIVE_SCENARIO=space

# Public demo URL (used in slides page).
#DEMO_URL=/

# Bind address and port for the app server.
#APP_HOST=0.0.0.0
#APP_PORT=80

# ── Twilio (SMS + Voice Alerts) — Optional ───────────────────────────────────
# Enables SMS and voice call notifications during demos.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# ── Slack (Webhook Alerts) — Optional ────────────────────────────────────────
# Enables Slack channel notifications during demos.
SLACK_WEBHOOK_URL=
