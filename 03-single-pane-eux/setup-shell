#!/usr/bin/env python3
"""
Exxon EUX Investigation Tool
Reads the five simulated data files and produces a unified timeline.
Determines root cause: AWS_FALLBACK, JITTER_DNS, or APPGATE_POLICY.
"""
import argparse, json, sys, os
from datetime import datetime

DATA_DIR = os.path.join(os.path.dirname(__file__), "data")

def load(filename):
    path = os.path.join(DATA_DIR, filename)
    with open(path) as f:
        return [json.loads(l) for l in f if l.strip()]

def check_aws_fallback(te_data, user_site="Midland-Field-Ops"):
    mpls = [d for d in te_data if "MPLS" in d.get("thousandeyes.agent.name","") and
            d.get("network.site") == user_site]
    if not mpls:
        return False, "No ThousandEyes data for site"
    avg_loss    = sum(d["thousandeyes.net.loss_pct"] for d in mpls) / len(mpls)
    avg_latency = sum(d["thousandeyes.net.latency_ms"] for d in mpls) / len(mpls)
    is_fallback = avg_loss > 5.0 or avg_latency > 150
    return is_fallback, f"avg_loss={avg_loss:.1f}% avg_latency={avg_latency:.0f}ms"

def check_jitter_dns(te_data, win_events, user="jsmith", user_site="Midland-Field-Ops"):
    mpls = [d for d in te_data if "MPLS" in d.get("thousandeyes.agent.name","") and
            d.get("network.site") == user_site]
    avg_jitter  = sum(d["thousandeyes.net.jitter_ms"] for d in mpls) / len(mpls) if mpls else 0
    avg_dns_rtt = sum(d["thousandeyes.dns.rtt_ms"] for d in mpls)    / len(mpls) if mpls else 0
    login_failures = [e for e in win_events if e.get("user.name") == user and
                      e.get("winlog.event_id") == 4625]
    high_jitter = avg_jitter > 20 and avg_dns_rtt > 60
    is_jitter_dns = high_jitter and len(login_failures) >= 2
    return is_jitter_dns, f"avg_jitter={avg_jitter:.1f}ms avg_dns_rtt={avg_dns_rtt:.0f}ms login_failures={len(login_failures)}"

def check_appgate_policy(appgate_data, iboss_data, user="jsmith"):
    denied = [d for d in appgate_data if d.get("user.name") == user and
              d.get("event.outcome") == "deny"]
    iboss_blocked = [d for d in iboss_data if d.get("user.name") == user and
                     d.get("event.outcome") == "blocked"]
    entitlements_denied = set(d.get("appgate.entitlement.name","") for d in denied)
    is_blocked = len(denied) >= 2 or len(iboss_blocked) >= 2
    return is_blocked, f"appgate_denials={len(denied)} iboss_blocks={len(iboss_blocked)} entitlements={list(entitlements_denied)}"

def main():
    parser = argparse.ArgumentParser(description="Exxon EUX Investigation")
    parser.add_argument("--user", default="jsmith")
    parser.add_argument("--check", choices=["aws-fallback", "jitter-dns", "appgate-block"])
    parser.add_argument("--full-report", action="store_true")
    args = parser.parse_args()

    avd      = load("avd-metrics.json")
    windows  = load("windows-events.json")
    iboss    = load("iboss-connections.json")
    appgate  = load("appgate-audit.json")
    te       = load("thousandeyes-metrics.json")

    user_avd = [d for d in avd if d.get("user.name") == args.user]
    user_site = user_avd[0].get("network.site", "Unknown") if user_avd else "Unknown"

    if args.check == "aws-fallback":
        result, detail = check_aws_fallback(te, user_site)
        status = "YES — AWS fallback detected" if result else "NO — circuit metrics normal"
        print(f"\n[AWS Fallback Check] {status}\n  Detail: {detail}\n")
        return

    if args.check == "jitter-dns":
        result, detail = check_jitter_dns(te, windows, args.user, user_site)
        status = "YES — Jitter DNS pattern detected" if result else "NO — DNS metrics normal"
        print(f"\n[Jitter DNS Check] {status}\n  Detail: {detail}\n")
        return

    if args.check == "appgate-block":
        result, detail = check_appgate_policy(appgate, iboss, args.user)
        status = "YES — AppGate/iboss policy block detected" if result else "NO — no policy blocks"
        print(f"\n[AppGate Policy Check] {status}\n  Detail: {detail}\n")
        return

    if args.full_report:
        print(f"\n{'='*60}")
        print(f"  Exxon EUX Investigation Report — user: {args.user}")
        print(f"  Site: {user_site}")
        print(f"{'='*60}\n")

        if user_avd:
            avg_logon     = sum(d.get("session.logon_duration_ms",0) for d in user_avd) / len(user_avd)
            avg_reconnect = sum(d.get("session.reconnect_count",0) for d in user_avd) / len(user_avd)
            print(f"  AVD Session Health:")
            print(f"    avg_logon_duration : {avg_logon/1000:.1f}s (normal: <5s)")
            print(f"    avg_reconnects     : {avg_reconnect:.1f}/session (normal: <1)")

        aws_result, aws_detail     = check_aws_fallback(te, user_site)
        dns_result, dns_detail     = check_jitter_dns(te, windows, args.user, user_site)
        ag_result,  ag_detail      = check_appgate_policy(appgate, iboss, args.user)

        print(f"\n  Signal Analysis:")
        print(f"    AWS Fallback   : {'DETECTED' if aws_result else 'not detected'} — {aws_detail}")
        print(f"    Jitter DNS     : {'DETECTED' if dns_result else 'not detected'} — {dns_detail}")
        print(f"    AppGate Policy : {'DETECTED' if ag_result  else 'not detected'} — {ag_detail}")

        causes = []
        if aws_result: causes.append("AWS_FALLBACK")
        if dns_result: causes.append("JITTER_DNS")
        if ag_result:  causes.append("APPGATE_POLICY")

        print(f"\n  {'─'*56}")
        if causes:
            primary = causes[0]
            print(f"  ROOT CAUSE: {primary}")
            if primary == "JITTER_DNS":
                print("  RECOMMENDATION: Notify WAN team of DNS jitter on Midland MPLS.")
                print("    Short-term: Force Azure AD auth over backup circuit.")
                print("    Long-term:  ThousandEyes alert threshold → Elastic alert rule.")
            elif primary == "APPGATE_POLICY":
                print("  RECOMMENDATION: Re-enroll avd-mid-w10-042 device cert in Intune.")
                print("    AppGate entitlement 'Audit-System-Access' requires valid cert.")
                print("    iboss policy 'exxon-internal-app-policy' also blocking same path.")
            elif primary == "AWS_FALLBACK":
                print("  RECOMMENDATION: Escalate MPLS circuit issue to WAN team.")
                print("    Traffic is currently routing via AWS transit — +60ms latency.")
        else:
            print("  ROOT CAUSE: UNKNOWN — no clear signal pattern detected.")

        if len(causes) > 1:
            print(f"  CONTRIBUTING FACTORS: {', '.join(causes[1:])}")
        print(f"  {'─'*56}\n")
        return

    parser.print_help()

if __name__ == "__main__":
    main()
PYEOF
