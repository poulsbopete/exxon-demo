    appgate = load("appgate-audit.json")
    te      = load("thousandeyes-metrics.json")

    # Aggregate AVD per user
    user_avd = defaultdict(list)
    for d in avd:
        user_avd[d.get("user.name","?")].append(d)

    avd_rows = ""
    for uname, sessions in sorted(user_avd.items()):
        avg_logon     = sum(s.get("session.logon_duration_ms",0) for s in sessions) / len(sessions)
        avg_reconnect = sum(s.get("session.reconnect_count",0) for s in sessions) / len(sessions)
        site = sessions[0].get("network.site","?")
        flag = " 🔴" if uname == "jsmith" else ""
        avd_rows += f"<tr><td><b>{html.escape(uname)}{flag}</b></td><td>{html.escape(site)}</td><td>{avg_logon/1000:.1f}s</td><td>{avg_reconnect:.1f}</td></tr>\n"

    win_rows = ""
    for e in [w for w in windows if w.get("user.name")=="jsmith"][:8]:
        eid = e.get("winlog.event_id","?")
        msg = html.escape(e.get("message","")[:90])
        flag = " 🔴" if eid == 4625 else ""
        win_rows += f"<tr><td>{html.escape(e.get('@timestamp',''))}</td><td><b>{eid}{flag}</b></td><td>{msg}</td></tr>\n"

    iboss_rows = ""
    for c in [i for i in iboss if i.get("user.name")=="jsmith"][:8]:
        outcome = c.get("event.outcome","?")
        color = "#d32f2f" if outcome == "blocked" else "#388e3c"
        iboss_rows += f"<tr><td>{html.escape(c.get('@timestamp',''))}</td><td style='color:{color}'><b>{html.escape(outcome).upper()}</b></td><td>{html.escape(c.get('destination.domain','?'))}</td><td>{html.escape(c.get('iboss.block.reason','—')[:60])}</td></tr>\n"

    ag_rows = ""
    for a in [g for g in appgate if g.get("user.name")=="jsmith"]:
        outcome = a.get("event.outcome","?")
        color = "#d32f2f" if outcome == "deny" else "#388e3c"
        ag_rows += f"<tr><td>{html.escape(a.get('@timestamp',''))}</td><td style='color:{color}'><b>{html.escape(outcome).upper()}</b></td><td>{html.escape(a.get('appgate.entitlement.name','?'))}</td><td>{html.escape(a.get('appgate.deny.reason','—')[:60])}</td></tr>\n"

    te_rows = ""
    midland_te = [t for t in te if "MID" in t.get("thousandeyes.agent.id","")][:10]
    for t in midland_te:
        jitter = t.get("thousandeyes.net.jitter_ms",0)
        color = "#d32f2f" if jitter > 20 else "#388e3c"
        te_rows += f"<tr><td>{html.escape(t.get('@timestamp',''))}</td><td>{html.escape(t.get('thousandeyes.agent.name','?'))}</td><td style='color:{color}'><b>{jitter:.1f}ms</b></td><td>{t.get('thousandeyes.net.loss_pct',0):.1f}%</td><td>{t.get('thousandeyes.dns.rtt_ms',0):.0f}ms</td></tr>\n"

    return f"""<!DOCTYPE html>
