class DashHandler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path in ("/", "/dashboard", "/index.html"):
            body = build_dashboard_html().encode()
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
        elif self.path == "/health":
            self.send_response(200)
            self.end_headers()
            self.wfile.write(b'{"status":"green"}')
        else:
            self.send_response(404)
            self.end_headers()

    def log_message(self, *a): pass

if __name__ == "__main__":
    import sys
    port = int(sys.argv[1]) if len(sys.argv) > 1 else 5601
    print(f"[INFO] EUX Dashboard server listening on :{port}")
    http.server.HTTPServer(("0.0.0.0", port), DashHandler).serve_forever()
