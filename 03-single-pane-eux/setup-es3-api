#!/bin/bash
set -euo pipefail
EUX_DIR="/root/exxon-eux"
PASS=0; FAIL=0

check_file() {
  local label="$1" file="$2" min_lines="$3"
  local count
  count=$(wc -l < "${EUX_DIR}/data/${file}" 2>/dev/null || echo 0)
  if [[ "$count" -ge "$min_lines" ]]; then
    records=$(grep -c "user.name\|thousandeyes" "${EUX_DIR}/data/${file}" 2>/dev/null || echo "$count")
    printf "  \033[32m✓\033[0m %-38s → %s records\n" "$label" "$count"
    PASS=$((PASS + 1))
  else
    printf "  \033[31m✗\033[0m %-38s → file missing or empty\n" "$label"
    FAIL=$((FAIL + 1))
  fi
}

echo ""
echo "Validating Challenge 3 — Single Pane EUX Investigation..."
echo ""

check_file "AVD session metrics loaded"        "avd-metrics.json"          5
check_file "Windows event log loaded"          "windows-events.json"       3
check_file "iboss connection log loaded"       "iboss-connections.json"    3
check_file "AppGate Zero Trust audit loaded"   "appgate-audit.json"        2
check_file "ThousandEyes circuit data loaded"  "thousandeyes-metrics.json" 5

# Run investigate.py and check it identifies a root cause
echo ""
if python3 "${EUX_DIR}/investigate.py" --full-report --user jsmith 2>/dev/null \
    | grep -q "ROOT CAUSE:"; then
  ROOT=$(python3 "${EUX_DIR}/investigate.py" --full-report --user jsmith 2>/dev/null \
    | grep "ROOT CAUSE:" | sed 's/.*ROOT CAUSE: //')
  printf "  \033[32m✓\033[0m %-38s → %s\n" "Root cause identified" "$ROOT"
  PASS=$((PASS + 1))
else
  printf "  \033[31m✗\033[0m %-38s\n" "Root cause not identified — run investigate.py"
  FAIL=$((FAIL + 1))
fi

echo ""
if [[ "$FAIL" -eq 0 ]]; then
  echo "  \033[32m✓ Challenge 3 complete — single pane of glass for end-user experience\033[0m"
  echo ""
  echo "  The answer: JITTER_DNS — WAN team DNS jitter from Midland MPLS is"
  echo "  causing Azure AD auth timeouts. AppGate and iboss are NOT the cause."
else
  echo "  ${FAIL} check(s) failed. Run the investigation scripts above."
fi
SCRIPT
