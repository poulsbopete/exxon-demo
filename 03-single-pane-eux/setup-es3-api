#!/usr/bin/env python3
"""
Exxon EUX Investigation Script
Reads the five simulated data files and produces a unified root-cause report.

Usage:
  python3 investigate.py --check aws-fallback --user jsmith
  python3 investigate.py --check jitter-dns  --user jsmith
  python3 investigate.py --check appgate-block --user jsmith
  python3 investigate.py --full-report --user jsmith
"""

import argparse, json, sys
from pathlib import Path

DATA = Path("/root/exxon-eux/data")


def load(name):
    path = DATA / name
    return [json.loads(l) for l in path.read_text().splitlines() if l.strip()]


def check_aws_fallback(user):
    te = [d for d in load("thousandeyes-metrics.json")
          if "midland" in d.get("thousandeyes.agent.name", "").lower()]
    high_loss = [d for d in te if d.get("thousandeyes.net.loss_pct", 0) > 5]
    high_lat  = [d for d in te if d.get("thousandeyes.net.latency_ms", 0) > 150]
    triggered = bool(high_loss or high_lat)
    print(f"\n  AWS Fallback check (packet loss >5% OR latency >150ms):")
    print(f"    Max loss:    {max((d.get('thousandeyes.net.loss_pct',0) for d in te), default=0):.1f}%  (threshold: 5%)")
    print(f"    Max latency: {max((d.get('thousandeyes.net.latency_ms',0) for d in te), default=0):.0f}ms (threshold: 150ms)")
    if triggered:
        print("    → TRIGGERED: AWS fallback is likely contributing")
    else:
        print("    → NOT triggered: AWS fallback is NOT the root cause")
    return triggered


def check_jitter_dns(user):
    te    = [d for d in load("thousandeyes-metrics.json")
             if "midland" in d.get("thousandeyes.agent.name", "").lower()]
    wins  = [d for d in load("windows-events.json")
             if d.get("user.name") == user and d.get("winlog.event_id") == 4625]
    high_dns_jitter = [d for d in te if d.get("thousandeyes.net.jitter_ms", 0) > 20]
    triggered = bool(high_dns_jitter and wins)
    print(f"\n  Jitter DNS check (WAN jitter >20ms AND Event ID 4625):")
    print(f"    Max DNS RTT: {max((d.get('thousandeyes.dns.rtt_ms',0) for d in te), default=0):.0f}ms")
    print(f"    Max jitter:  {max((d.get('thousandeyes.net.jitter_ms',0) for d in te), default=0):.0f}ms  (threshold: 20ms)")
    print(f"    Event 4625 count: {len(wins)}")
    if triggered:
        print("    → TRIGGERED: Jitter DNS is causing Azure AD auth timeouts")
    else:
        print("    → NOT triggered")
    return triggered


def check_appgate_block(user):
    ag = [d for d in load("appgate-audit.json")
          if d.get("user.name") == user and d.get("event.outcome") == "denied"]
    ib = [d for d in load("iboss-connections.json")
          if d.get("user.name") == user and d.get("event.outcome") == "blocked"
          and "audit" in d.get("destination.domain", "")]
    triggered = bool(ag or ib)
    print(f"\n  AppGate/iboss block check:")
    print(f"    AppGate denied events for {user}: {len(ag)}")
    print(f"    iboss blocked to audit.exxon.internal: {len(ib)}")
    if triggered:
        print("    → TRIGGERED: AppGate/iboss is blocking access")
    else:
        print("    → NOT triggered: AppGate and iboss are allowing access")
    return triggered


def full_report(user):
    print(f"\n{'='*60}")
    print(f"  Exxon EUX Investigation — User: {user}")
    print(f"  Host: avd-mid-w10-042  |  Site: Midland Field Ops")
    print(f"{'='*60}")

    # AVD summary
    avd = [d for d in load("avd-metrics.json") if d.get("user.name") == user]
    if avd:
        avg_logon = sum(d.get("session.logon_duration_ms", 0) for d in avd) / len(avd)
        max_recon = max(d.get("session.reconnect_count", 0) for d in avd)
        print(f"\n  Panel A — AVD Session:")
        print(f"    Avg logon duration: {avg_logon/1000:.1f}s  (normal: <5s)")
        print(f"    Max reconnect count: {max_recon}  (normal: 0)")

    # Windows events
    wins = [d for d in load("windows-events.json") if d.get("user.name") == user]
    ev4625 = [d for d in wins if d.get("winlog.event_id") == 4625]
    print(f"\n  Panel B — Windows Events:")
    print(f"    Total events: {len(wins)}")
    print(f"    Event 4625 (auth failure): {len(ev4625)}")

    # iboss
    iboss = [d for d in load("iboss-connections.json") if d.get("user.name") == user]
    blocked = [d for d in iboss if d.get("event.outcome") == "blocked"]
    print(f"\n  Panel C — iboss:")
    print(f"    Total connections: {len(iboss)} | Blocked: {len(blocked)}")

    # AppGate
    ag = [d for d in load("appgate-audit.json") if d.get("user.name") == user]
    denied = [d for d in ag if d.get("event.outcome") == "denied"]
    print(f"\n  Panel D — AppGate:")
    print(f"    Policy evaluations: {len(ag)} | Denied: {len(denied)}")

    # ThousandEyes
    te = [d for d in load("thousandeyes-metrics.json")
          if "midland" in d.get("thousandeyes.agent.name", "").lower()]
    if te:
        max_j   = max(d.get("thousandeyes.net.jitter_ms", 0) for d in te)
        max_dns = max(d.get("thousandeyes.dns.rtt_ms", 0) for d in te)
        max_loss= max(d.get("thousandeyes.net.loss_pct", 0) for d in te)
        print(f"\n  Panel E — ThousandEyes (Midland MPLS):")
        print(f"    Max jitter:    {max_j:.0f}ms")
        print(f"    Max DNS RTT:   {max_dns:.0f}ms  ← elevated")
        print(f"    Max loss:      {max_loss:.1f}%")

    print(f"\n{'='*60}")

    aws  = check_aws_fallback(user)
    dns  = check_jitter_dns(user)
    ag_b = check_appgate_block(user)

    print(f"\n{'='*60}")
    print(f"  ROOT CAUSE ANALYSIS:")
    if dns and not aws and not ag_b:
        print("  → ROOT CAUSE: JITTER_DNS")
        print("     WAN DNS jitter from Midland MPLS is causing Azure AD auth")
        print("     timeouts (Event 4625). The user is reconnecting repeatedly")
        print("     because each Kerberos ticket renewal fails due to DNS RTT")
        print("     spikes. AppGate and iboss are NOT blocking — this is a WAN")
        print("     team issue, not Security or Desktop.")
        print()
        print("  Fix: WAN team to investigate DNS server 10.14.1.53 in Midland.")
        print("       Short-term: switch to public DNS (8.8.8.8) for Azure AD.")
    elif aws:
        print("  → ROOT CAUSE: AWS_FALLBACK")
    elif ag_b:
        print("  → ROOT CAUSE: APPGATE_POLICY")
    else:
        print("  → ROOT CAUSE: UNDETERMINED — collect more data.")
    print(f"{'='*60}\n")


if __name__ == "__main__":
    parser = argparse.ArgumentParser()
    parser.add_argument("--check", choices=["aws-fallback","jitter-dns","appgate-block"])
    parser.add_argument("--full-report", action="store_true")
    parser.add_argument("--user", default="jsmith")
    args = parser.parse_args()

    if args.check == "aws-fallback":
        check_aws_fallback(args.user)
    elif args.check == "jitter-dns":
        check_jitter_dns(args.user)
    elif args.check == "appgate-block":
        check_appgate_block(args.user)
    elif args.full_report:
        full_report(args.user)
    else:
        parser.print_help()
PYEOF
chmod +x "${EUX_DIR}/investigate.py"
log "Created ${EUX_DIR}/investigate.py ✓"

