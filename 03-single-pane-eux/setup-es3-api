#!/bin/bash
# Challenge 3 setup — files already exist from track_scripts/setup-es3-api.
DEMO_PORT=8090
log() { printf "[challenge-3-setup] %s\n" "$*"; }

for i in $(seq 1 10); do
  curl -sf "http://localhost:${DEMO_PORT}/health" >/dev/null 2>&1 && { log "Demo app healthy ✓"; exit 0; }
  sleep 2
done

log "WARN: Demo app not responding — attempting restart..."
systemctl restart exxon-demo 2>/dev/null || true
sleep 8
curl -sf "http://localhost:${DEMO_PORT}/health" >/dev/null 2>&1 \
  && log "Demo app healthy after restart ✓" \
  || log "WARN: App not healthy. Run: journalctl -u exxon-demo -n 50"

ls /root/exxon-eux/data/avd-metrics.json >/dev/null 2>&1 \
  && log "Challenge files ready ✓" \
  || log "WARN: /root/exxon-eux/ not found — track setup may still be running"

exit 0
