# Normal circuit loss is <1%, jitter <5ms, DNS <20ms
for i in range(7):
    dt = base + datetime.timedelta(minutes=i*10)
    jitter = 4 + i * 8          # 4ms → 52ms (severe by t+60min)
    dns_rtt = 18 + i * 12       # 18ms → 90ms (Jitter DNS)
