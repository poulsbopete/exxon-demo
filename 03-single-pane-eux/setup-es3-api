cat > "${EUX_DIR}/queries/eux-investigation.esql" << 'ESQL'
// EUX Unified Investigation Query
// user.name and host.name are the correlation keys across all 5 data streams.
// Run in Elastic Serverless tab → Dev Tools → ES|QL

// Step 1 — AVD session health for the affected user
FROM metrics-azure.avd-*
| WHERE @timestamp > NOW() - 90 minutes
  AND user.name == "jsmith"
| STATS
    avg_logon_s   = AVG(session.logon_duration_ms) / 1000,
    max_reconnects = MAX(session.reconnect_count),
    avg_input_delay_ms = AVG(session.input_delay_ms)
  BY host.name, user.name

// Step 2 — Windows auth failures on that host
// FROM logs-windows.forwarded-*
// | WHERE winlog.event_id == 4625 AND host.name == "avd-mid-w10-042"
// | STATS auth_failures = COUNT(*) BY host.name

// Step 3 — ThousandEyes circuit jitter from Midland
// FROM metrics-thousandeyes.*
// | WHERE thousandeyes.agent.name LIKE "*midland*"
// | STATS max_jitter_ms = MAX(thousandeyes.net.jitter_ms),
//         max_dns_rtt_ms = MAX(thousandeyes.dns.rtt_ms)

// Correlation: all three queries share the Midland site context.
// In the full dashboard, user.name -> host.name -> avd.host.region -> thousandeyes.agent.location
// creates the end-to-end chain: User impact → Desktop event → WAN root cause.
ESQL
